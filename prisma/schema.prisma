generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AudioItem {
  id                  String   @id @default(uuid())
  title               String
  topic               String
  course              String
  filePath            String
  duration            Int?
  createdAt           DateTime @default(now())
  lastPositionSeconds Int      @default(0)
}
